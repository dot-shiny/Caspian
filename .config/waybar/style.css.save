* {
    font-family: "JetBrainsMono Nerd Font";
    font-size: 14px;
    font-weight: bold;
}

window#waybar {
    background-color: #73022f;
    border-bottom: 0px solid #333333;
    margin: 0;
}


#workspaces, #cpu, #memory, #disk, #temperature, #network, #battery, #clock {
    background-color: #fa0567;
    color: white;
    border-radius: 6px;
    padding: 0 10px;
    margin: 0 4px;
    border-bottom: 0px solid #b30464
}

#workspaces button {
    color: white;
    padding: 0 5px;
    background-color: transparent;
}

#workspacees button.active {
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: 5px;
}
